[Unit]
Description=PurpleHaze (Xxium Backend)
After=network.target

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/purplehaze/backend
ExecStartPre=/opt/purplehaze/backend/.venv/bin/pip install -q -r /opt/purplehaze/backend/requirements.txt
ExecStart=/opt/purplehaze/backend/.venv/bin/python -m uvicorn main:app --host 0.0.0.0 --port 34357 --workers 1
Restart=always
RestartSec=5
Environment=PPH_DATA_DIR=/opt/purplehaze/data

[Install]
WantedBy=multi-user.target
